# Supabase Public
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Private
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Proxy (set to "true" to route browser requests through your domain)
# Use this if ISPs are blocking supabase.co (e.g. in India)
NEXT_PUBLIC_SUPABASE_PROXY=true

# Ollama
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434

# API Keys (Optional: Entering an API key here overrides the API keys globally for all users.)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=

# OpenAI API Information
NEXT_PUBLIC_OPENAI_ORGANIZATION_ID=

# Azure API Information
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_GPT_35_TURBO_NAME=
AZURE_GPT_45_VISION_NAME=
AZURE_GPT_45_TURBO_NAME=
AZURE_EMBEDDINGS_NAME=

# General Configuration (Optional)
EMAIL_DOMAIN_WHITELIST=
EMAIL_WHITELIST=

# File size limit for uploads in bytes
NEXT_PUBLIC_USER_FILE_SIZE_LIMIT=10485760

# Rate limiting (Upstash Redis REST)
# Required in production - without these, rate limiting fails open.
# Create a free Redis at https://upstash.com and paste the REST URL/TOKEN.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Inngest signature verification
# Required in production - protects /api/inngest from forged event payloads.
# Grab the signing key from the Inngest dashboard → your app → Keys.
INNGEST_SIGNING_KEY=

# ── Billing / metering ──────────────────────────────────────────────────────
# Token metering ALWAYS records usage (needs SUPABASE_SERVICE_ROLE_KEY above).
# The hard 402 over-limit BLOCK is gated separately so you can launch
# metering-only, validate the credit calibration against real usage, then turn
# enforcement on with no redeploy. Default (unset) = record but never block.
# Set to true/1/on/yes to enforce the cap.
BILLING_ENFORCE=

# Free-tier experiment paywall: free users get FREE_EXPERIMENT_LIMIT (lib/billing
# /plans.ts, default 3) GENERATED designs, then must upgrade. Like BILLING_ENFORCE
# this is count-only by default - set EXPERIMENT_PAYWALL=true/1/on/yes to actually
# BLOCK a 4th design generation for free users (returns 402 EXPERIMENT_LIMIT).
EXPERIMENT_PAYWALL=

# ── RevenueCat (Web Billing) - required for paid plans + credit packs ────────
# Until NEXT_PUBLIC_REVENUECAT_WEB_PUBLIC_KEY is set, the payment path stays
# dormant (Free works; upgrades show "Coming soon"). See BILLING.md for the
# RevenueCat dashboard setup (entitlements pro/max, products, offering, webhook).
NEXT_PUBLIC_REVENUECAT_WEB_PUBLIC_KEY=
NEXT_PUBLIC_REVENUECAT_PRO_PACKAGE=
NEXT_PUBLIC_REVENUECAT_MAX_PACKAGE=
NEXT_PUBLIC_REVENUECAT_CREDITS_PACKAGE=
NEXT_PUBLIC_REVENUECAT_PORTAL_URL=
# Server: must equal the Authorization header set on the RevenueCat webhook.
REVENUECAT_WEBHOOK_AUTH=
# Server: JSON map of one-time credit-pack product id → raw token count,
# e.g. {"credits_20k":20000000}. Required for credit packs to grant anything.
REVENUECAT_CREDIT_PRODUCTS=

# --- Influencer affiliate / creator program --------------------------------
# Shared bearer secret for the operator-only admin endpoints
# (POST /api/admin/affiliate to mint a creator code, POST /api/admin/comp to
# grant a comp Max plan). Fail-closed: if unset, those endpoints reject all
# calls. Generate a long random value and keep it secret.
ADMIN_API_SECRET=
# Public site origin used to build creator share links (e.g.
# https://shadowai.work). Falls back to the request origin if unset.
NEXT_PUBLIC_SITE_URL=